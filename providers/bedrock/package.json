{
  "name": "@genui-a3/a3-bedrock",
  "version": "0.0.2",
  "description": "AWS Bedrock provider for the A3 agentic framework",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup --config ../tsup.config.ts",
    "dev": "tsup --config ../tsup.config.ts --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "a3",
    "providers",
    "bedrock",
    "aws",
    "ai",
    "llm"
  ],
  "author": "GenUI <https://genui.com>",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@genui-a3/a3": ">=0.0.1"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.47",
    "@aws-sdk/client-bedrock-runtime": "3.1011.0",
    "zod": "4.3.6"
  }
}
