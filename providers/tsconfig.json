{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "strict": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": ["esnext"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@genui-a3/core": ["../dist/index.d.ts"],
      "openai": ["../node_modules/openai"],
      "openai/*": ["../node_modules/openai/*"]
    }
  },
  "include": ["bedrock/**/*.ts", "openai/**/*.ts", "utils/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
