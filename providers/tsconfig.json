{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "allowJs": false,
    "target": "ES2022",
    "module": "ESNext",
    "declaration": true,
    "declarationMap": true,
    "lib": ["esnext"],
    "types": ["node"],
    "paths": {
      "@genui-a3/a3": ["../dist/index.d.ts"],
      "@providers": ["./src"],
      "@providers/*": ["./src/*"],
      "@providers-anthropic": ["./anthropic"],
      "@providers-anthropic/*": ["./anthropic/*"],
      "@providers-bedrock": ["./bedrock"],
      "@providers-bedrock/*": ["./bedrock/*"],
      "@providers-openai": ["./openai"],
      "@providers-openai/*": ["./openai/*"],
      "@providers-utils": ["./utils"],
      "@providers-utils/*": ["./utils/*"]
    }
  }
}
