    "access": "public"
  },
  "peerDependencies": {
    "@genui-a3/core": ">=0.1.5"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.47",
    "@aws-sdk/client-bedrock-runtime": "3.975.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "20.19.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  }
}
