{
  "config": {
    "default": true,
    "first-line-h1": false,
    "line-length": {
      "line_length": 280,
    },
    "no-inline-html": {
      "allowed_elements": ["a", "br", "div", "h1", "img", "p"],
    },
    "table-column-style": false,
  },
  "ignores": [
    "**/no_commit/**",
    "**/node_modules/**",
    "src/agents/**",
    "**/SPECS.md",
    "**/.terraform/**",
    "**/.venv/**",
  ],
}
