{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["esnext", "dom"],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node", "jest", "@testing-library/jest-dom"],
    "outDir": "./dist"
  },
  "include": ["src/**/*.ts", "__tests__/**/*.ts", "jest.*.ts"],
  "exclude": ["node_modules", "no_commit", "dist"]
}
