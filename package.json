{
  "name": "@genui/a3",
  "version": "0.1.37",
  "description": "Predictable, governable multi-agent orchestration for TypeScript",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "workspaces": [
    "providers/bedrock",
    "providers/openai",
    "providers/anthropic",
    "example",
    "create"
  ],
  "scripts": {
    "build": "run-s build:core build:providers build:example",
    "build:core": "tsup",
    "build:providers": "npm run build -w @genui/a3-bedrock -w @genui/a3-openai -w @genui/a3-anthropic",
    "build:example": "npm run build -w example",
    "clean": "rm -rf dist",
    "dev": "run-p dev:core dev:providers example:dev",
    "dev:core": "tsup --watch",
    "dev:providers": "npm run dev -w @genui/a3-bedrock -w @genui/a3-openai -w @genui/a3-anthropic",
    "example:dev": "cd example && npm run dev",
    "example:setup": "cd example && npm i",
    "example:start": "cd example && npm run start",
    "lint": "run-p lint:project lint:markdown",
    "lint:markdown": "markdownlint-cli2 '**/*.md'",
    "lint:project": "eslint './**/*.{ts,tsx}' --max-warnings=0 --cache --cache-location .eslintcache",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "run-p test:unit test:integration",
    "test:coverage": "run-p test:unit:coverage",
    "test:integration": "jest --config jest.integration.config.ts",
    "test:integration:watch": "npm run test:integration -- --watch",
    "test:unit": "jest __tests__/unit",
    "test:unit:create": "jest __tests__/unit/create --passWithNoTests",
    "test:unit:create:coverage": "npm run test:unit:create -- --coverage --collectCoverageFrom='create/**/*.{ts,tsx}'",
    "test:unit:core": "jest __tests__/unit/src",
    "test:unit:core:coverage": "npm run test:unit:core -- --coverage --collectCoverageFrom='src/**/*.{ts,tsx}'",
    "test:unit:coverage": "npm run test:unit -- --coverage",
    "test:unit:providers": "jest __tests__/unit/providers",
    "test:unit:providers:coverage": "npm run test:unit:providers -- --coverage --collectCoverageFrom='providers/**/*.{ts,tsx}'",
    "test:unit:watch": "jest __tests__/unit --watch",
    "test:watch": "run-p test:unit:watch test:integration:watch"
  },
  "keywords": [
    "ai",
    "agents",
    "multi-agent",
    "orchestration",
    "llm",
    "chatbot",
    "typescript",
    "zod",
    "structured-output",
    "bedrock",
    "openai",
    "anthropic",
    "agentic",
    "framework",
    "a3",
    "genui"
  ],
  "author": "GenUI <https://genui.com>",
  "contributors": [
    {
      "name": "Alejandro Panza"
    },
    {
      "name": "Stanley Jovel"
    },
    {
      "name": "Tom Jones"
    },
    {
      "name": "Steven Asher"
    },
    {
      "name": "Jon Ryser"
    }
  ],
  "license": "MIT",
  "homepage": "https://genui.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/generalui/a3.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.47",
    "@loglayer/transport-tslog": "4.0.2",
    "loglayer": "9.1.0",
    "tslog": "4.10.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@faker-js/faker": "10.2.0",
    "@testing-library/jest-dom": "6.9.1",
    "@types/jest": "30.0.0",
    "@types/node": "20.19.0",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "30.2.0",
    "jest-environment-jsdom": "30.2.0",
    "jest-mock-extended": "4.0.0",
    "markdownlint-cli2": "0.21.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.1",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  },
  "overrides": {},
  "directories": {
    "doc": "docs",
    "example": "example"
  },
  "bugs": {
    "url": "https://github.com/generalui/a3/issues"
  }
}
