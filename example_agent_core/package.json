{
  "name": "example_agent_core",
  "version": "1.0.0",
  "description": "A3 + AWS Bedrock AgentCore example",
  "type": "module",
  "main": "dist/agent_core_entry.js",
  "scripts": {
    "preinstall": "if [ -d ../dist ]; then rm -rf npm_modules/@genui-a3 && mkdir -p npm_modules/@genui-a3/core && cp -r ../dist/* npm_modules/@genui-a3/core && cp modules-package.json npm_modules/@genui-a3/core/package.json; fi",
    "build": "tsc",
    "start": "node dist/agent_core_entry.js",
    "dev": "npx tsx --watch agent_core_entry.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "GenUI",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "3.975.0",
    "@aws-sdk/client-cloudformation": "3.975.0",
    "@datadog/browser-logs": "6.25.4",
    "@genui-a3/core": "file:./npm_modules/@genui-a3/core",
    "@opentelemetry/auto-instrumentations-node": "^0.56.0",
    "bedrock-agentcore": "^0.2.0",
    "chrono-node": "2.9.0",
    "date-fns": "4.1.0",
    "loglevel": "1.9.2",
    "winston": "3.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
