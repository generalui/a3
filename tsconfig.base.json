{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@constants": ["./src/constants"],
      "@constants/*": ["./src/constants/*"],
      "@core": ["./src/core"],
      "@core/*": ["./src/core/*"],
      "@create-utils": ["./create/src/utils"],
      "@create-utils/*": ["./create/src/utils/*"],
      "@prompts": ["./src/prompts"],
      "@prompts/*": ["./src/prompts/*"],
      "@providers": ["./providers"],
      "@providers/*": ["./providers/*"],
      "@providers-anthropic": ["./providers/anthropic"],
      "@providers-anthropic/*": ["./providers/anthropic/*"],
      "@providers-bedrock": ["./providers/bedrock"],
      "@providers-bedrock/*": ["./providers/bedrock/*"],
      "@providers-openai": ["./providers/openai"],
      "@providers-openai/*": ["./providers/openai/*"],
      "@providers-utils": ["./providers/utils"],
      "@providers-utils/*": ["./providers/utils/*"],
      "@utils": ["./src/utils"],
      "@utils/*": ["./src/utils/*"],
      "types": ["./src/types"],
      "types/*": ["./src/types/*"],
      "@stores": ["./src/stores"],
      "@stores/*": ["./src/stores/*"],
      "@errors": ["./src/errors"],
      "@errors/*": ["./src/errors/*"]
    }
  }
}
