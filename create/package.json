{
  "name": "@genui-a3/create",
  "version": "0.1.4",
  "description": "CLI scaffolding tool for A3 agentic apps",
  "keywords": [
    "genui",
    "a3",
    "ai",
    "agentic",
    "architecture",
    "scaffold",
    "cli"
  ],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "create-genui-a3": "dist/index.js"
  },
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "build": "npm run prepare-template && tsup",
    "postbuild": "chmod +x dist/index.js",
    "clean": "rm -rf dist template",
    "prepare-template": "node scripts/prepare-template.mjs",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "5.4.1",
    "fs-extra": "11.3.0",
    "prompts": "2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/node": "20.19.0",
    "@types/prompts": "2.4.9",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  }
}
